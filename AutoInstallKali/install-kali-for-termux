red='\033[1;31m'
yellow='\033[1;33m'
blue='\033[1;34m'
reset='\033[0m'

# ==================== 清理函数 ====================

pre_cleanup() {
    find "$HOME" -maxdepth 1 -name "kali*" -type d -exec rm -rf {} \; 2>/dev/null || :
}

post_cleanup() {
    find "$HOME" -maxdepth 1 -name "kali-nethunter-rootfs-*" -type f -exec rm -rf {} \; 2>/dev/null || :
}

# ==================== 架构检测 ====================

setchroot() {
    printf "$blue 访问 https://kali.download/nethunter-images/current/rootfs/ 查看可用的 Chroot 版本\n"
    printf "请选择 Chroot 类型：\n"
    printf "  [1] full      (~1.6G 下载, 完整 Kali 工具集)\n"
    printf "  [2] minimal   (~130M 下载, 精简版)\n"
    printf "  [3] nano      (~190M 下载, 最小版)\n"

    read -p "请输入选择 (1/2/3): " choice

    case $choice in
        1) chroot="full" ;;
        2) chroot="minimal" ;;
        3) chroot="nano" ;;
        *)
            printf "$red 选择无效，请输入 1、2 或 3。$reset\n"
            exit 1
            ;;
    esac
    echo "已选择 Chroot 类型: $chroot"
}

unknownarch() {
    printf "$red[*] 未知架构 :($reset\n"
    exit 1
}

checksysinfo() {
    printf "$blue[*] 检测主机架构 ...$reset\n"
    case $(getprop ro.product.cpu.abi) in
        arm64-v8a)
            SETARCH=arm64 ;;
        armeabi|armeabi-v7a)
            SETARCH=armhf ;;
        *)
            unknownarch ;;
    esac
    echo "  检测到架构: $SETARCH"
}

# ==================== 依赖检查 ====================

checkdeps() {
    printf "${blue}[*] 更新 apt 缓存...${reset}\n"
    apt update -y &>/dev/null
    printf "${blue}[*] 检查依赖工具...${reset}\n"

    for i in proot tar; do
        if [ -e "$PREFIX/bin/$i" ]; then
            echo "  - $i 已安装"
        else
            echo "  安装 ${i}..."
            apt install -y "$i" || {
                printf "$red 错误：无法安装 $i，请检查网络或 apt 源。$reset\n"
                exit 1
            }
        fi
    done

    # 优先用 wget，其次 axel
    if [ -e "$PREFIX/bin/wget" ]; then
        DOWNLOADER="wget"
    elif [ -e "$PREFIX/bin/axel" ]; then
        DOWNLOADER="axel"
    else
        echo "  安装 wget..."
        apt install -y wget && DOWNLOADER="wget" || {
            echo "  尝试安装 axel..."
            apt install -y axel && DOWNLOADER="axel" || {
                printf "$red 错误：无法安装下载工具。$reset\n"
                exit 1
            }
        }
    fi
    echo "  下载工具: $DOWNLOADER"

    apt upgrade -y
}

# ==================== 下载 ====================

seturl() {
    URL="https://kali.download/nethunter-images/current/rootfs/kali-nethunter-rootfs-${chroot}-${SETARCH}.tar.xz"
}

gettarfile() {
    printf "$blue[*] 获取 tar 文件...$reset\n"
    DESTINATION="$HOME/kali-${SETARCH}"
    seturl
    mkdir -p "$DESTINATION"
    cd "$HOME"
    rootfs="kali-nethunter-rootfs-${chroot}-${SETARCH}.tar.xz"
    if [ -f "$rootfs" ]; then
        # 如果已下载 SHA256SUMS，先校验已有文件
        if [ -f "SHA256SUMS" ]; then
            local expected=$(grep "rootfs-${chroot}-${SETARCH}.tar.xz" SHA256SUMS | awk '{print $1}')
            if [ -n "$expected" ]; then
                local actual=$(sha256sum "$rootfs" | awk '{print $1}')
                if [ "$expected" = "$actual" ]; then
                    printf "  已有 $rootfs 且校验通过，跳过下载
"
                    return
                else
                    printf "${yellow}[!] 已有文件校验失败，将重新下载${reset}
"
                    rm -f "$rootfs"
                fi
            fi
        else
            printf "${yellow}[!] 已存在 $rootfs，跳过下载 (无校验文件，如损坏请手动删除)
"
            return
        fi
    fi

    printf "  下载地址: $URL\n"

    if [ "$DOWNLOADER" = "axel" ]; then
        axel ${EXTRAARGS} "$URL" || {
            printf "$red 下载失败，请检查网络连接。$reset\n"
            exit 1
        }
    else
        wget ${EXTRAARGS} --show-progress -O "$rootfs" "$URL" || {
            printf "$red 下载失败，请检查网络连接。$reset\n"
            exit 1
        }
    fi
}

# ==================== SHA256 校验 ====================

getchecksum() {
    printf "$blue[*] 获取 SHA256SUMS ...$reset\n"
    cd "$HOME"
    local sums_url="https://kali.download/nethunter-images/current/rootfs/SHA256SUMS"

    if [ "$DOWNLOADER" = "axel" ]; then
        axel -o SHA256SUMS "$sums_url" 2>/dev/null || {
            printf "$yellow[!] 校验文件下载失败，跳过完整性校验。$reset\n"
            return 1
        }
    else
        wget -q -O SHA256SUMS "$sums_url" 2>/dev/null || {
            printf "$yellow[!] 校验文件下载失败，跳过完整性校验。$reset\n"
            return 1
        }
    fi
}

checkintegrity() {
    printf "$blue[*] 校验文件完整性 (SHA256)...$reset
"
    cd "$HOME"
    if [ ! -f "SHA256SUMS" ]; then
        printf "$yellow[!] 无校验文件，跳过。$reset
"
        return
    fi
    # SHA256SUMS 文件名带版本号，下载文件名不带，用后缀匹配
    local expected=$(grep "rootfs-${chroot}-${SETARCH}.tar.xz" SHA256SUMS | awk '{print $1}')
    local actual=$(sha256sum "$rootfs" | awk '{print $1}')
    if [ -z "$expected" ]; then
        printf "$yellow[!] SHA256SUMS 中未找到匹配项，跳过。$reset
"
        return
    fi
    if [ "$expected" = "$actual" ]; then
        printf "  校验通过
"
    else
        printf "$red  校验失败！下载的文件可能已损坏。$reset
"
        printf "$red  期望: $expected$reset
"
        printf "$red  实际: $actual$reset
"
        printf "$red  请删除 $rootfs 和 SHA256SUMS 后重新运行脚本。$reset
"
        exit 1
    fi
}

# ==================== 解压 ====================

extract() {
    printf "$blue[*] 解压 rootfs 到 $DESTINATION ...$reset\n"
    cd "$HOME"
    # 如果已解压，跳过
    if [ -d "$DESTINATION/bin" ] && [ -d "$DESTINATION/etc" ]; then
        printf "  $DESTINATION 已存在，跳过解压
"
        return
    fi

    # 检查磁盘空间
    local avail=$(df -h "$HOME" 2>/dev/null | awk 'NR==2 {print $4}')
    if [ -n "$avail" ]; then
        printf "  磁盘剩余: $avail\n"
    fi

    # 检查 tar 文件
    if [ ! -f "$rootfs" ]; then
        printf "$red  未找到 $rootfs，请重新下载。$reset\n"
        exit 1
    fi
    local fsize=$(stat -c%s "$rootfs" 2>/dev/null || stat -f%z "$rootfs" 2>/dev/null || echo 0)
    if [ "$fsize" -lt 1048576 ]; then
        printf "$red  $rootfs 文件过小 ($fsize bytes)，可能下载不完整。$reset\n"
        printf "$red  请删除后重试: rm $HOME/$rootfs$reset\n"
        exit 1
    fi
    printf "  文件大小: $fsize bytes\n"
    # 解压 (Android 环境下权限/所有者设置失败属正常，exit code 2 可忽略)
    printf "  正在解压 (可能需要几分钟)...
"
    local ret=0
    # 用临时文件记录 stderr，避免管道吞掉 tar 的实际退出码
    proot --link2symlink tar -xf "$rootfs" -C "$HOME" 2>$HOME/tar-error.log || ret=$?
    # 显示非权限相关的错误
    grep -vE '(Cannot change ownership|Cannot set permissions|无法设置)' $HOME/tar-error.log 2>/dev/null || true
    rm -f $HOME/tar-error.log
    if [ "$ret" -eq 0 ] || [ "$ret" -eq 2 ]; then
        if [ -d "$DESTINATION/bin" ] || [ -d "$DESTINATION/etc" ]; then
            printf "  解压完成"
            [ "$ret" -eq 2 ] && printf " (忽略权限警告)"
            printf "
"
        else
            printf "
$red  解压不完整，关键目录缺失。请删除后重试。$reset
"
            exit 1
        fi
    else
        printf "
$red  解压失败！(exit code: $ret)$reset
"
        printf "$red  可能原因: 磁盘空间不足、tar 文件损坏。$reset
"
        printf "$red  手动调试: tar -xf $HOME/$rootfs -C $HOME$reset
"
        exit 1
    fi
}

# ==================== 登录脚本 ====================

createloginfile() {
    bin="$PREFIX/bin/kali"
    printf "$blue[*] 创建登录脚本: $bin$reset\n"

    cat > "$bin" <<- EOM
#!/data/data/com.termux/files/usr/bin/bash -e
unset LD_PRELOAD

if [ ! -f ${DESTINATION}/root/.version ]; then
    touch ${DESTINATION}/root/.version
fi
user=kali
home="/home/\$user"
LOGIN="sudo -u \$user /bin/bash"
if [[ ("\$#" != "0" && ("\$1" == "-r")) ]]; then
    user=root
    home="/\$user"
    LOGIN="/bin/bash --login"
    shift
fi

cmd="proot \
    --link2symlink \
    -0 \
    -r ${DESTINATION} \
    -b /dev \
    -b /proc \
    -b ${DESTINATION}/dev:/dev/shm \
    -b /sdcard \
    -b ${HOME} \
    -w \${home} \
    /usr/bin/env -i \
    HOME=\${home} \
    TERM=\${TERM} \
    LANG=\${LANG} \
    PATH=/bin:/usr/bin:/sbin:/usr/sbin \
    \${LOGIN}"

args="\$@"
if [ "\$#" == 0 ]; then
    exec \$cmd
else
    \$cmd -c "\$args"
fi
EOM
    chmod 700 "$bin"
}

# ==================== resolv.conf ====================

resolvconf() {
    mkdir -p "${DESTINATION}/etc"
    printf "nameserver 8.8.8.8\nnameserver 8.8.4.4" > "${DESTINATION}/etc/resolv.conf"
}

# ==================== finalwork ====================

finalwork() {
    DESTINATION="$DESTINATION" SETARCH="$SETARCH" bash "$HOME/termux-install-kali/AutoInstallKali/env.sh"
}

# ==================== 界面 ====================

printline() {
    printf "${blue}\n #---------------------------------#${reset}\n"
}

# ==================== 主流程 ====================

clear
EXTRAARGS=""
if [ ! -z "$1" ]; then
    EXTRAARGS="$1"
fi

printf "\n${yellow} 您即将在 Termux 上安装 Kali Nethunter (Rootless)${reset}\n\n"

pre_cleanup
checksysinfo
checkdeps
setchroot
getchecksum
gettarfile
checkintegrity
extract
createloginfile
post_cleanup

printf "$blue[*] 正在配置 Kali ...$reset\n"
resolvconf
finalwork

printline
printf "${yellow}  现在可以使用 'kali' 命令进入 Kali Nethunter！${reset}\n"
printf "${yellow}  使用 'kali -r' 以 root 身份登录。${reset}\n"
printline
printf "${blue}[*] 原始项目: GitHub/Hax4us (hax4us.com)${reset}\n"
printf "${blue}[*] 修复版本: luther${reset}\n"
printline
